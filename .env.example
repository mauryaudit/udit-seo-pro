# ─────────────────────────────────────────────────────────────
#  udit-seo-pro — Environment Configuration
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# Semrush API Key (required for keyword/backlink/competitor data)
# Get/rotate yours at: https://www.semrush.com/api-analytics/
SEMRUSH_API_KEY=your_semrush_api_key_here

# Target domain (used as default when no URL is passed)
TARGET_DOMAIN=

# Optional: Semrush database (regional SERP)
# Options: us, uk, ca, au, in, de, fr, es, it, jp, br, ru, etc.
SEMRUSH_DATABASE=in
